# Base de datos
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/jocoso

# JWT — genera un secret seguro: openssl rand -base64 64
JWT_SECRET=cambia-esto-por-un-secret-seguro

# Servidor
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:4200

# MercadoPago — obtener en mercadopago.cl/developers
MP_ACCESS_TOKEN=TEST-...
MP_WEBHOOK_SECRET=tu-webhook-secret
MP_WEBHOOK_URL=https://tu-dominio.com/api/v1/payments/webhook
FRONTEND_URL=http://localhost:4200

# MercadoLibre — obtener en developers.mercadolibre.cl
ML_APP_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://tu-dominio.com/api/v1/ml/oauth/callback
ML_WEBHOOK_URL=https://tu-dominio.com/api/v1/ml/webhooks
