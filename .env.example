# ─── App ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/app

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ─── MercadoPago ────────────────────────────────────────────────────────────
# Get from https://www.mercadopago.cl/developers/panel/app
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxx   # usar TEST- para sandbox
MP_WEBHOOK_SECRET=                  # configurar en panel MP → Webhooks
MP_WEBHOOK_URL=https://TU_DOMINIO/api/v1/payments/webhook
FRONTEND_URL=https://TU_DOMINIO_FRONTEND

# ─── MercadoLibre ───────────────────────────────────────────────────────────
ML_APP_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://TU_DOMINIO/api/v1/ml/oauth/callback
ML_WEBHOOK_URL=https://TU_DOMINIO/api/v1/ml/webhooks
